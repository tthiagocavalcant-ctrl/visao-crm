{
  "name": "Meta Lead Ads → CRM Pipeline",
  "nodes": [
    {
      "parameters": {
        "updates": ["leadgen"]
      },
      "name": "Meta Lead Ads",
      "type": "n8n-nodes-base.facebookLeadAdsTrigger",
      "typeVersion": 1,
      "position": [240, 300],
      "webhookId": "meta-leads-crm-webhook"
    },
    {
      "parameters": {
        "jsCode": "const fields = $input.item.json.field_data || [];\n\nconst get = (name) => {\n  const f = fields.find(f => f.name === name);\n  return f ? f.values[0] : null;\n};\n\n// Tenta pegar nome completo, ou junta primeiro + último nome\nconst name = get('full_name') ||\n  `${get('first_name') || ''} ${get('last_name') || ''}`.trim() ||\n  'Lead sem nome';\n\n// Remove tudo que não é número do telefone\nconst phone = (get('phone_number') || '').replace(/\D/g, '');\n\nconst source = [\n  $input.item.json.campaign_name,\n  $input.item.json.ad_name\n].filter(Boolean).join(' — ') || 'Meta Lead Ads';\n\nreturn [{\n  json: {\n    account_id: 'aca1cf0c-c4a8-4a12-9dd0-71a66941b790',\n    name,\n    phone,\n    email: get('email') || null,\n    canal: 'facebook',\n    source,\n  }\n}];"
      },
      "name": "Mapear Campos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://ywgqrutamfepvouflecp.supabase.co/functions/v1/receive-n8n-lead",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify($json) }}"
      },
      "name": "Enviar para CRM",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.phone }}",
              "operation": "isNotEmpty"
            }
          ]
        }
      },
      "name": "Tem telefone?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [570, 300]
    }
  ],
  "connections": {
    "Meta Lead Ads": {
      "main": [
        [{ "node": "Mapear Campos", "type": "main", "index": 0 }]
      ]
    },
    "Mapear Campos": {
      "main": [
        [{ "node": "Tem telefone?", "type": "main", "index": 0 }]
      ]
    },
    "Tem telefone?": {
      "main": [
        [{ "node": "Enviar para CRM", "type": "main", "index": 0 }],
        []
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
